<ul class="navbar-nav">

    <li class="nav-item">
        @if (!(User.Identity?.IsAuthenticated ?? false)) {
            <a class="nav-link" href="/Identity/Account/Login">
                Login
            </a>
        } else {
            <li class="nav-item">
                <span class="nav-link">@User.Identity?.Name</span>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Identity/Account/Logout">Logout</a>
            </li>
        }
    </li>
</ul>