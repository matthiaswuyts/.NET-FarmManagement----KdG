@model IEnumerable<FarmManagement.BL.Domain.Farm>

@{
     ViewData["Title"] = "List of Farms";
}

     <h1>All Farms</h1> 
     <table class="table">
          <thead>
          <tr>
               <th>Name</th>
               <th>Location</th>
               <th>Size in Hectares</th>
               <th>Established Year</th>
               <th></th>
          </tr>
          </thead>
          <tbody class="table-group-divider">
          @foreach (var farm in Model)
          {
               <tr>
                    <td>@farm.Name</td>
                    <td>@farm.Location</td>
                    <td>@(farm.SizeInHectares.HasValue ? $"{farm.SizeInHectares}": "Unknown" )</td>
                    <td>@farm.EstablishedYear</td>
                    <td><a asp-controller="Farm" asp-action="Details" asp-route-farmId="@farm.Id">Details</a></td>
               </tr>
          }
          </tbody>
     </table>

